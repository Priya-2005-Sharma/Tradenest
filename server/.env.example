# Copy to .env and adjust. The committed .env works out of the box for local dev.

NODE_ENV=development
PORT=5000

# Leave empty to auto-start an in-memory MongoDB (no install needed, no persistence).
# For persistence, point at a local mongod or MongoDB Atlas:
#   MONGO_URI=mongodb://127.0.0.1:27017/tradenest
#   MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tradenest
MONGO_URI=

# Generate a strong value for any real deployment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=tradenest-dev-secret-change-me
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed browser origins.
CLIENT_ORIGIN=http://localhost:5173

COOKIE_NAME=tradenest_token
